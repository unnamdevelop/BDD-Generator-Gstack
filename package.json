{
  "name": "bdd-generator",
  "version": "0.1.0",
  "description": "JIRA webhook → BDD scenario generator",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["bdd", "gherkin", "jira", "webhook"],
  "author": "Ragha",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.21.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "@cucumber/gherkin": "^27.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
